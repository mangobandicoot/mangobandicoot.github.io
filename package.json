{
  "name": "full-throttle-rpg",
  "version": "1.0.0",
  "description": "Full Throttle Racing Career RPG",
  "main": "rpg-main.js",
  "scripts": {
    "start":             "electron .",
    "build-win-portable":"electron-builder --win portable --x64",
    "build-win":         "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.fullthrottle.rpg",
    "productName": "Full Throttle RPG",
    "directories": { "output": "dist" },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Full Throttle RPG"
    },
    "files": [ "rpg.html", "rpg-main.js", "rpg-preload.js" ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "author": "Full Throttle",
  "license": "MIT"
}